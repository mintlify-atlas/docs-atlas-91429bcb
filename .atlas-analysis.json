  "keyFeatures": [
    "Parallel chunk generation using multiple CPU cores",
    "Async chunk I/O with configurable caching",
    "Rewritten chunk system for improved scheduling and throughput",
    "Density function compiler (JVM bytecode) for faster world generation",
    "Native SIMD acceleration (AVX2/AVX512) for math-heavy worldgen",
    "No-tick view distance support with extended render distance protocol",
    "Threading fixes for vanilla worldgen and general thread safety",
    "Configurable auto-save modes (VANILLA, ENHANCED, PERIODIC)",
    "POI unloading to prevent memory leaks in long-running worlds",
    "Fluid post-processing optimizations to reduce server tick spikes"
  ],
  "publicApiSurface": [
    "c2me.toml config: generalOptimizations.midTickChunkTasksInterval",
    "c2me.toml config: generalOptimizations.autoSave.mode (VANILLA/ENHANCED/PERIODIC)",
