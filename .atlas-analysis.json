    "c2me.toml config: vanillaWorldGenOptimizations.nativeAcceleration.enabled",
    "c2me.toml config: vanillaWorldGenOptimizations.nativeAcceleration.allowAVX512",
    "c2me.toml config: noTickViewDistance.maxConcurrentChunkLoads",
    "c2me.toml config: noTickViewDistance.enableExtRenderDistanceProtocol",
